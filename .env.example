# ─── Base de données ──────────────────────────────────────────────────────────
POSTGRES_USER=gestion_user
POSTGRES_PASSWORD=changeme_in_production

# ─── Authentification ─────────────────────────────────────────────────────────
JWT_SECRET=changeme_super_secret_jwt_key_256bits

# ─── Message Broker ───────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092

# ─── Cache ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Ports individuels (développement local sans Docker) ──────────────────────
USER_SERVICE_PORT=3001
SALE_SERVICE_PORT=3002
CRM_SERVICE_PORT=3003
COMMISSION_SERVICE_PORT=3004
PLANNING_SERVICE_PORT=3005
RISTOURNE_SERVICE_PORT=3006
STOCK_SERVICE_PORT=3007
CONTENT_SERVICE_PORT=3008
NOTIFICATION_SERVICE_PORT=3009
FRONTEND_PORT=5173
